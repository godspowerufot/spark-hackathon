# Deployer wallet private key (0x-prefixed). Never commit the real key.
PRIVATE_KEY=

# Optional RPC overrides (defaults to apps/web/.env.local NEXT_PUBLIC_RPC_URL)
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC_URL=https://rpc.monad.xyz

# Initial max claim amount in wei (default = 0.01 MON)
MAX_CLAIM_WEI=10000000000000000

# Written automatically by the deploy script
LEDGER_ADDRESS=
